{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2024,
    "sourceType": "module"
  },
  "plugins": ["security", "no-unsanitized", "@typescript-eslint"],
  "extends": [
    "plugin:security/recommended",
    "plugin:no-unsanitized/DOM"
  ],
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  }
}
